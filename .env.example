# Copy to .env.local for local dev. NEVER commit the real .env.local.
# On Vercel these all go in Project → Settings → Environment Variables.

# -----------------------------------------------------------------------------
# Database — a Postgres connection string from Supabase (free tier is plenty).
# Create a project at https://supabase.com/dashboard, then grab
# Project Settings → Database → Connection string → "Transaction pooler"
# (port 6543). The app sets `prepare: false` so the transaction pooler works.
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres.xxxxxxxxxxxx:PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# -----------------------------------------------------------------------------
# Auth — shared password gate. Rotate SESSION_SECRET periodically.
# SESSION_SECRET must be at least 16 chars (use a password manager generator).
# -----------------------------------------------------------------------------
DASHBOARD_PASSWORD=change-me
SESSION_SECRET=replace-with-a-long-random-string

# Vercel sends `Authorization: Bearer $CRON_SECRET` to /api/cron/* when set.
CRON_SECRET=another-long-random-string

# -----------------------------------------------------------------------------
# Printavo — GraphQL API credentials for Chris's account.
# Get these from Printavo → My Account → API.
# -----------------------------------------------------------------------------
PRINTAVO_EMAIL=chris@allstarturlock.com
PRINTAVO_TOKEN=your-printavo-api-token-here

# -----------------------------------------------------------------------------
# Google Places API (new). Enable the "Places API (New)" in a GCP project
# and restrict the key to your Vercel deployment domain.
# -----------------------------------------------------------------------------
GOOGLE_PLACES_API_KEY=your-google-places-key-here
